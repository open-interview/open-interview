{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "answer-auditor": {
      "mode": "primary",
      "description": "Bulk-scans all questions, audits answers against the answer standard, marks failing questions for reprocessing, and triggers processor-bot to fix them",
      "model": "opencode/big-pickle",
      "temperature": 0.1,
      "permission": {
        "bash": {
          "node script/bots/answer-auditor-bot.js *": "allow",
          "node script/bots/processor-bot.js *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "*": "deny"
        },
        "edit": "deny"
      }
    },
    "poll-orchestrator": {
      "mode": "primary",
      "description": "Orchestrates the entire LinkedIn poll generation workflow, coordinating specialized agents",
      "model": "opencode/big-pickle",
      "temperature": 0.3,
      "permission": {
        "task": {
          "poll-researcher": "allow",
          "poll-generator": "allow",
          "poll-reviewer": "allow",
          "poll-poster": "allow"
        }
      }
    },
    "poll-researcher": {
      "mode": "subagent",
      "description": "Researches real-world use cases and incidents for LinkedIn polls using web search",
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "grep *": "allow",
          "*": "deny"
        }
      }
    },
    "poll-generator": {
      "mode": "subagent",
      "description": "Generates debate-driven LinkedIn poll questions and options based on research",
      "model": "opencode/big-pickle",
      "temperature": 0.4
    },
    "poll-reviewer": {
      "mode": "subagent",
      "description": "Reviews generated polls for quality, engagement potential, and LinkedIn best practices",
      "model": "opencode/big-pickle",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "poll-poster": {
      "mode": "subagent",
      "description": "Handles LinkedIn posting logistics, template selection, and hashtag strategy",
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "website-auditor": {
      "mode": "primary",
      "description": "Audits websites for SEO, performance, security, technical, content, and 15 other issue categories with 230+ rules",
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "squirrelscan *": "allow",
          "npx squirrelscan *": "allow",
          "*": "deny"
        },
        "edit": "deny"
      }
    },
    "browser-automator": {
      "mode": "primary",
      "description": "Automates browser interactions for web testing, form filling, screenshots, and data extraction",
      "model": "opencode/big-pickle",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "playwright *": "allow",
          "npx playwright *": "allow",
          "node *": "allow",
          "python *": "allow",
          "*": "deny"
        }
      }
    },
    "copywriter": {
      "mode": "primary",
      "description": "Writes, rewrites, and improves marketing copy for landing pages, product pages, and campaigns",
      "model": "opencode/big-pickle",
      "temperature": 0.7,
      "permission": {
        "bash": {
          "grep *": "allow",
          "cat *": "allow",
          "*": "deny"
        }
      }
    },
    "frontend-designer": {
      "mode": "primary",
      "description": "Creates distinctive, production-grade frontend interfaces with high design quality",
      "model": "opencode/big-pickle",
      "temperature": 0.4,
      "permission": {
        "bash": {
          "npm *": "allow",
          "npx *": "allow",
          "pnpm *": "allow",
          "node *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "playwright-tester": {
      "mode": "primary",
      "description": "Designs and implements Playwright end-to-end tests with best practices for web applications",
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "npx playwright *": "allow",
          "playwright *": "allow",
          "npm test *": "allow",
          "npx playwright test *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "presentation-generator": {
      "mode": "primary",
      "description": "Creates, edits, and processes PowerPoint presentations (.pptx files)",
      "model": "opencode/big-pickle",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "python *": "allow",
          "node *": "allow",
          "npx *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "pdf-processor": {
      "mode": "primary",
      "description": "Reads, extracts, combines, splits, and processes PDF files",
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "python *": "allow",
          "node *": "allow",
          "pdftk *": "allow",
          "qpdf *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "seo-auditor": {
      "mode": "primary",
      "description": "Audits websites for SEO issues including technical SEO, on-page optimization, Core Web Vitals, and ranking factors",
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "squirrelscan *": "allow",
          "npx squirrelscan *": "allow",
          "lighthouse *": "allow",
          "npx lighthouse *": "allow",
          "*": "deny"
        },
        "edit": "deny"
      }
    },
    "ui-ux-designer": {
      "mode": "primary",
      "description": "Creates interface designs, wireframes, and design systems with user research and accessibility focus",
      "model": "opencode/big-pickle",
      "temperature": 0.5,
      "permission": {
        "bash": {
          "grep *": "allow",
          "cat *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "project-planner": {
      "mode": "primary",
      "description": "Plans project execution paths, decomposes tasks, identifies risks, and manages progress for high-quality delivery",
      "model": "opencode/big-pickle",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "grep *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "git *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    }
  }
}
