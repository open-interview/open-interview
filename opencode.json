{
  "$schema": "https://opencode.ai/config.json",
  "model": "kiro-gateway/auto-kiro",
  "provider": {
    "kiro-gateway": {
      "npm": "@ai-sdk/openai",
      "name": "Kiro Gateway",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "opencode-kiro-gateway-2026"
      },
      "models": {
        "auto-kiro": {
          "name": "Kiro Auto (Gateway)",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 1000000, "output": 64000 }
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 (Gateway)",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 200000, "output": 8192 }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Gateway)",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 1000000, "output": 64000 }
        },
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6 (Gateway)",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 1000000, "output": 64000 }
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5 (Gateway)",
          "reasoning": false,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 200000, "output": 8192 }
        },
        "deepseek-3-2": {
          "name": "DeepSeek 3.2 (Gateway)",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 128000, "output": 4096 }
        },
        "minimax-m2-1": {
          "name": "MiniMax M2.1 (Gateway)",
          "reasoning": false,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 200000, "output": 4096 }
        },
        "minimax-m2-5": {
          "name": "MiniMax M2.5 (Gateway)",
          "reasoning": false,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 200000, "output": 4096 }
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next (Gateway)",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 256000, "output": 8192 }
        }
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "answer-auditor": {
      "mode": "primary",
      "description": "Bulk-scans all questions, audits answers against the answer standard, marks failing questions for reprocessing, and triggers processor-bot to fix them",
      "model": "kiro/claude-opus-4.6",
      "temperature": 0.1,
      "permission": {
        "bash": {
          "node script/bots/answer-auditor-bot.js *": "allow",
          "node script/bots/processor-bot.js *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "*": "deny"
        },
        "edit": "deny"
      }
    },
    "poll-orchestrator": {
      "mode": "primary",
      "description": "Orchestrates the entire LinkedIn poll generation workflow, coordinating specialized agents",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.3,
      "permission": {
        "task": {
          "poll-researcher": "allow",
          "poll-generator": "allow",
          "poll-reviewer": "allow",
          "poll-poster": "allow"
        }
      }
    },
    "poll-researcher": {
      "mode": "subagent",
      "description": "Researches real-world use cases and incidents for LinkedIn polls using web search",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "grep *": "allow",
          "*": "deny"
        }
      }
    },
    "poll-generator": {
      "mode": "subagent",
      "description": "Generates debate-driven LinkedIn poll questions and options based on research",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.4
    },
    "poll-reviewer": {
      "mode": "subagent",
      "description": "Reviews generated polls for quality, engagement potential, and LinkedIn best practices",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "poll-poster": {
      "mode": "subagent",
      "description": "Handles LinkedIn posting logistics, template selection, and hashtag strategy",
      "model": "kiro/claude-haiku-4.5",
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "website-auditor": {
      "mode": "primary",
      "description": "Audits websites for SEO, performance, security, technical, content, and 15 other issue categories with 230+ rules",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "squirrelscan *": "allow",
          "npx squirrelscan *": "allow",
          "*": "deny"
        },
        "edit": "deny"
      }
    },
    "browser-automator": {
      "mode": "primary",
      "description": "Automates browser interactions for web testing, form filling, screenshots, and data extraction",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "playwright *": "allow",
          "npx playwright *": "allow",
          "node *": "allow",
          "python *": "allow",
          "*": "deny"
        }
      }
    },
    "copywriter": {
      "mode": "primary",
      "description": "Writes, rewrites, and improves marketing copy for landing pages, product pages, and campaigns",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.7,
      "permission": {
        "bash": {
          "grep *": "allow",
          "cat *": "allow",
          "*": "deny"
        }
      }
    },
    "frontend-designer": {
      "mode": "primary",
      "description": "Creates distinctive, production-grade frontend interfaces with high design quality",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.4,
      "permission": {
        "bash": {
          "npm *": "allow",
          "npx *": "allow",
          "pnpm *": "allow",
          "node *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "playwright-tester": {
      "mode": "primary",
      "description": "Designs and implements Playwright end-to-end tests with best practices for web applications",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "npx playwright *": "allow",
          "playwright *": "allow",
          "npm test *": "allow",
          "npx playwright test *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "presentation-generator": {
      "mode": "primary",
      "description": "Creates, edits, and processes PowerPoint presentations (.pptx files)",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "python *": "allow",
          "node *": "allow",
          "npx *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "pdf-processor": {
      "mode": "primary",
      "description": "Reads, extracts, combines, splits, and processes PDF files",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "python *": "allow",
          "node *": "allow",
          "pdftk *": "allow",
          "qpdf *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "seo-auditor": {
      "mode": "primary",
      "description": "Audits websites for SEO issues including technical SEO, on-page optimization, Core Web Vitals, and ranking factors",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.2,
      "permission": {
        "bash": {
          "squirrelscan *": "allow",
          "npx squirrelscan *": "allow",
          "lighthouse *": "allow",
          "npx lighthouse *": "allow",
          "*": "deny"
        },
        "edit": "deny"
      }
    },
    "ui-ux-designer": {
      "mode": "primary",
      "description": "Creates interface designs, wireframes, and design systems with user research and accessibility focus",
      "model": "kiro/claude-sonnet-4.6",
      "temperature": 0.5,
      "permission": {
        "bash": {
          "grep *": "allow",
          "cat *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    },
    "project-planner": {
      "mode": "primary",
      "description": "Plans project execution paths, decomposes tasks, identifies risks, and manages progress for high-quality delivery",
      "model": "kiro/claude-opus-4.6",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "grep *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "git *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "write": "allow"
      }
    }
  }
}
