---
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-slate-800/60 bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <div class="flex h-7 w-7 items-center justify-center rounded-md bg-blue-600 text-white font-mono text-xs font-bold">OI</div>
          <span class="font-semibold text-slate-200">Open Interview Blog</span>
        </div>
        <p class="text-sm text-slate-500 leading-relaxed">
          Real-world engineering stories and technical deep-dives to help you ace your next technical interview.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold text-slate-300 mb-3 uppercase tracking-wider">Explore</h3>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-slate-300 transition-colors">All Posts</a></li>
          <li><a href="/tags" class="hover:text-slate-300 transition-colors">Browse Tags</a></li>
          <li><a href="/rss.xml" class="hover:text-slate-300 transition-colors">RSS Feed</a></li>
          <li><a href="/sitemap-index.xml" class="hover:text-slate-300 transition-colors">Sitemap</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold text-slate-300 mb-3 uppercase tracking-wider">Resources</h3>
        <ul class="space-y-2 text-sm text-slate-500">
          <li><a href="https://open-interview.github.io" class="hover:text-slate-300 transition-colors">Practice Questions</a></li>
          <li><a href="https://open-interview.github.io/flashcards" class="hover:text-slate-300 transition-colors">Flashcards</a></li>
          <li><a href="https://open-interview.github.io/voice-interview" class="hover:text-slate-300 transition-colors">Voice Interview</a></li>
          <li><a href="https://github.com/open-interview/open-interview" class="hover:text-slate-300 transition-colors">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-slate-800/60 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-600">
      <p>© {year} Open Interview. Open source under MIT license.</p>
      <p>Built with <span class="text-slate-500">Astro</span> + <span class="text-slate-500">Tailwind CSS</span></p>
    </div>
  </div>
</footer>
