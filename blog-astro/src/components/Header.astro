---
const navLinks = [
  { href: '/', label: 'Blog' },
  { href: '/tags', label: 'Tags' },
  { href: '/rss.xml', label: 'RSS', external: true },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-slate-800/60 bg-slate-950/80 backdrop-blur-xl">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-600 text-white font-mono text-sm font-bold group-hover:bg-blue-500 transition-colors">
          OI
        </div>
        <span class="font-semibold text-slate-100 group-hover:text-white transition-colors">
          Open<span class="text-blue-400">Interview</span>
          <span class="text-slate-500 font-normal ml-1">/ Blog</span>
        </span>
      </a>

      <!-- Nav -->
      <nav class="flex items-center gap-1">
        {navLinks.map(link => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class:list={[
              'rounded-lg px-3 py-1.5 text-sm font-medium transition-colors',
              currentPath === link.href
                ? 'bg-blue-600/20 text-blue-400'
                : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800',
            ]}
          >
            {link.label}
            {link.external && (
              <svg class="inline ml-0.5 h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            )}
          </a>
        ))}

        <!-- Main site link -->
        <a
          href="https://open-interview.github.io"
          class="ml-2 rounded-lg border border-blue-600/40 bg-blue-600/10 px-3 py-1.5 text-sm font-medium text-blue-400 hover:bg-blue-600/20 transition-colors"
        >
          Practice Questions →
        </a>
      </nav>
    </div>
  </div>
</header>
