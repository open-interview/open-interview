---
import type { CollectionEntry } from 'astro:content';
import { formatDate, getCategoryClass, getDifficultyClass } from '../utils/helpers';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, excerpt, category, tags, publishedAt, difficulty, readingTimeMinutes } = post.data;
---

<article
  class:list={[
    'group flex flex-col rounded-2xl border bg-slate-900/60 transition-all duration-200',
    'hover:border-blue-500/40 hover:bg-slate-900 hover:shadow-lg hover:shadow-blue-500/5 hover:-translate-y-0.5',
    featured ? 'border-blue-500/20' : 'border-slate-800/60',
  ]}
>
  <a href={`/blog/${post.slug}`} class="flex flex-col gap-4 p-6 flex-1">
    <!-- Top row: category + difficulty -->
    <div class="flex items-center gap-2 flex-wrap">
      <span class:list={['rounded-md px-2 py-0.5 text-xs font-medium', getCategoryClass(category)]}>
        {category}
      </span>
      <span class:list={['rounded-md px-2 py-0.5 text-xs font-medium', getDifficultyClass(difficulty)]}>
        {difficulty}
      </span>
      {featured && (
        <span class="ml-auto rounded-md px-2 py-0.5 text-xs font-medium bg-yellow-500/15 text-yellow-300 border border-yellow-500/30">
          ★ Featured
        </span>
      )}
    </div>

    <!-- Title -->
    <h2 class:list={[
      'font-bold leading-snug text-slate-100 group-hover:text-blue-300 transition-colors',
      featured ? 'text-xl' : 'text-lg',
    ]}>
      {title}
    </h2>

    <!-- Excerpt -->
    <p class="text-sm text-slate-400 leading-relaxed line-clamp-3 flex-1">
      {excerpt}
    </p>

    <!-- Meta row -->
    <div class="flex items-center justify-between text-xs text-slate-500 pt-2 border-t border-slate-800/60">
      <time datetime={publishedAt.toISOString()}>
        {formatDate(publishedAt)}
      </time>
      <span class="flex items-center gap-1">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        {readingTimeMinutes} min read
      </span>
    </div>
  </a>

  <!-- Tags row -->
  {tags.length > 0 && (
    <div class="px-6 pb-5 flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map(tag => (
        <a
          href={`/tag/${tag}`}
          class="rounded-full border border-slate-700/60 bg-slate-800/60 px-2 py-0.5 text-xs text-slate-400 hover:border-blue-500/40 hover:text-blue-300 transition-colors"
          onclick="event.stopPropagation()"
        >
          #{tag}
        </a>
      ))}
      {tags.length > 3 && (
        <span class="rounded-full border border-slate-700/40 px-2 py-0.5 text-xs text-slate-600">
          +{tags.length - 3}
        </span>
      )}
    </div>
  )}
</article>
