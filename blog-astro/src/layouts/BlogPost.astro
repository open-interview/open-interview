---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { formatDateFull, getCategoryClass, getDifficultyClass } from '../utils/helpers';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
}

const { post, headings, prevPost, nextPost } = Astro.props;
const { title, excerpt, category, tags, publishedAt, difficulty, readingTimeMinutes, author } = post.data;

const h2headings = headings.filter(h => h.depth === 2);
---

<BaseLayout title={title} description={excerpt}>
  <div id="reading-progress"></div>
  <Header />

  <main class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[1fr_260px]">
      <!-- Article -->
      <article>
        <!-- Back link -->
        <a
          href="/"
          class="mb-8 inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-300 transition-colors"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          Back to Blog
        </a>

        <!-- Badges -->
        <div class="mb-5 flex flex-wrap items-center gap-2">
          <span class:list={['rounded-md px-2.5 py-1 text-xs font-semibold', getCategoryClass(category)]}>
            {category}
          </span>
          <span class:list={['rounded-md px-2.5 py-1 text-xs font-semibold', getDifficultyClass(difficulty)]}>
            {difficulty}
          </span>
        </div>

        <!-- Title -->
        <h1 class="mb-6 text-3xl font-extrabold leading-tight text-white sm:text-4xl">
          {title}
        </h1>

        <!-- Meta -->
        <div class="mb-10 flex flex-wrap items-center gap-4 border-b border-slate-800 pb-8 text-sm text-slate-500">
          <div class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-600/20 text-blue-400 text-xs font-bold">
              {author.charAt(0)}
            </div>
            <span class="text-slate-400">{author}</span>
          </div>
          <time datetime={publishedAt.toISOString()} class="flex items-center gap-1.5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            {formatDateFull(publishedAt)}
          </time>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            {readingTimeMinutes} min read
          </span>
        </div>

        <!-- Content -->
        <div class="prose prose-lg max-w-none">
          <slot />
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-12 pt-8 border-t border-slate-800">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500 mb-4">Tags</h3>
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <a
                  href={`/tag/${tag}`}
                  class="rounded-full border border-slate-700 bg-slate-800/60 px-3 py-1 text-sm text-slate-400 hover:border-blue-500/50 hover:text-blue-300 transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Prev / Next navigation -->
        <nav class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {prevPost && (
            <a
              href={`/blog/${prevPost.slug}`}
              class="group flex flex-col gap-1 rounded-xl border border-slate-800 bg-slate-900/60 p-5 hover:border-blue-500/40 transition-all"
            >
              <span class="text-xs text-slate-500 flex items-center gap-1">
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                Previous
              </span>
              <span class="text-sm font-medium text-slate-300 group-hover:text-blue-300 line-clamp-2 transition-colors">
                {prevPost.data.title}
              </span>
            </a>
          )}
          {nextPost && (
            <a
              href={`/blog/${nextPost.slug}`}
              class:list={[
                'group flex flex-col gap-1 rounded-xl border border-slate-800 bg-slate-900/60 p-5 hover:border-blue-500/40 transition-all',
                !prevPost && 'sm:col-start-2',
              ]}
            >
              <span class="text-xs text-slate-500 flex items-center gap-1 justify-end">
                Next
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
              </span>
              <span class="text-sm font-medium text-slate-300 group-hover:text-blue-300 line-clamp-2 transition-colors text-right">
                {nextPost.data.title}
              </span>
            </a>
          )}
        </nav>
      </article>

      <!-- Sidebar TOC -->
      {h2headings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-wider text-slate-500">
              On This Page
            </h3>
            <nav class="space-y-1" id="toc">
              {h2headings.map(h => (
                <a
                  href={`#${h.slug}`}
                  class="toc-link block rounded-lg px-3 py-1.5 text-sm text-slate-500 hover:bg-slate-800/60 hover:text-slate-300 transition-colors"
                  data-heading={h.slug}
                >
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Reading progress bar
  const progressBar = document.getElementById('reading-progress');
  if (progressBar) {
    const updateProgress = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = `${Math.min(progress, 100)}%`;
    };
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  // Active TOC link highlighting
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  if (tocLinks.length > 0) {
    const headingEls = Array.from(
      document.querySelectorAll<HTMLElement>('article h2[id]')
    );
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(link => {
              link.classList.remove('bg-blue-600/15', 'text-blue-400', 'font-medium');
              if (link.dataset.heading === entry.target.id) {
                link.classList.add('bg-blue-600/15', 'text-blue-400', 'font-medium');
              }
            });
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px' }
    );
    headingEls.forEach(el => observer.observe(el));
  }

  // Mermaid: transform <pre><code class="language-mermaid"> → <div class="mermaid">
  const mermaidBlocks = document.querySelectorAll('pre code.language-mermaid');
  if (mermaidBlocks.length > 0) {
    mermaidBlocks.forEach(block => {
      const pre = block.parentElement!;
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = block.textContent ?? '';
      pre.parentElement!.replaceChild(div, pre);
    });

    // Load mermaid from CDN
    const script = document.createElement('script');
    script.type = 'module';
    script.textContent = `
      import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
      mermaid.initialize({
        startOnLoad: true,
        theme: 'dark',
        themeVariables: {
          primaryColor: '#3b82f6',
          primaryTextColor: '#e2e8f0',
          primaryBorderColor: '#334155',
          lineColor: '#64748b',
          secondaryColor: '#1e293b',
          tertiaryColor: '#0f172a',
          background: '#0f172a',
          mainBkg: '#1e293b',
          nodeBorder: '#334155',
          edgeLabelBackground: '#1e293b',
          fontFamily: 'Inter, sans-serif',
        },
      });
    `;
    document.head.appendChild(script);
  }

  // Copy code button
  document.querySelectorAll('pre').forEach(pre => {
    if (pre.classList.contains('mermaid')) return;
    const btn = document.createElement('button');
    btn.className = 'copy-btn absolute right-2 top-2 rounded-md bg-slate-700/60 px-2 py-1 text-xs text-slate-400 opacity-0 group-hover:opacity-100 hover:bg-slate-600 hover:text-slate-200 transition-all';
    btn.textContent = 'Copy';
    pre.style.position = 'relative';
    pre.classList.add('group');
    btn.addEventListener('click', async () => {
      const code = pre.querySelector('code')?.textContent ?? '';
      await navigator.clipboard.writeText(code).catch(() => {});
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = 'Copy'), 2000);
    });
    pre.appendChild(btn);
  });
</script>

<style>
  .prose :global(h2)::before {
    content: '## ';
    color: #3b82f6;
    opacity: 0.4;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75em;
  }
</style>
