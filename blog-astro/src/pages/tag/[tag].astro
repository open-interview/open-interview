---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const tagMap: Record<string, typeof allPosts> = {};

  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      if (!tagMap[tag]) tagMap[tag] = [];
      tagMap[tag].push(post);
    }
  }

  return Object.entries(tagMap).map(([tag, posts]) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`Posts tagged: #${tag}`} description={`${posts.length} posts tagged #${tag}`}>
  <Header />
  <main class="mx-auto max-w-6xl px-4 py-12">
    <!-- Header -->
    <div class="mb-10">
      <a href="/tags" class="mb-4 inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-300 transition-colors">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        All Tags
      </a>
      <div class="flex items-center gap-3">
        <span class="rounded-xl border border-blue-500/30 bg-blue-500/10 px-4 py-2 text-xl font-bold text-blue-300">
          #{tag}
        </span>
        <span class="text-slate-500 text-sm">{posts.length} post{posts.length !== 1 ? 's' : ''}</span>
      </div>
    </div>

    <!-- Posts grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map(post => <PostCard post={post} />)}
    </div>
  </main>
  <Footer />
</BaseLayout>
