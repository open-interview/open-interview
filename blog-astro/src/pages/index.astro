---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

const featuredPosts = allPosts.filter(p => p.data.featured).slice(0, 3);

const categories = [...new Set(allPosts.map(p => p.data.category))].sort();

const postsByCategory: Record<string, typeof allPosts> = {};
for (const post of allPosts) {
  if (!postsByCategory[post.data.category]) postsByCategory[post.data.category] = [];
  postsByCategory[post.data.category].push(post);
}

const totalPosts = allPosts.length;
const totalCategories = categories.length;
---

<BaseLayout title="Open Interview Blog — Technical Engineering Deep-Dives">
  <Header />

  <main class="mx-auto max-w-6xl px-4">
    <!-- Hero -->
    <section class="py-16 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-500/30 bg-blue-500/10 px-4 py-1.5 text-sm text-blue-300">
        <span class="h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse"></span>
        {totalPosts} posts across {totalCategories} topics
      </div>
      <h1 class="mt-4 text-4xl font-extrabold text-white sm:text-5xl lg:text-6xl leading-tight">
        Engineering
        <span class="gradient-text"> Deep-Dives</span>
      </h1>
      <p class="mt-5 max-w-2xl mx-auto text-lg text-slate-400 leading-relaxed">
        Real-world outage stories, system design patterns, and battle-tested techniques from engineers at FAANG and beyond.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a
          href="https://open-interview.github.io"
          class="rounded-xl bg-blue-600 hover:bg-blue-500 px-6 py-2.5 text-sm font-semibold text-white transition-colors"
        >
          Practice Interview Questions →
        </a>
        <a
          href="/rss.xml"
          class="rounded-xl border border-slate-700 bg-slate-800/60 hover:bg-slate-800 px-6 py-2.5 text-sm font-semibold text-slate-300 transition-colors"
        >
          Subscribe via RSS
        </a>
      </div>
    </section>

    <!-- Category Filter -->
    <section class="mb-10">
      <div class="flex flex-wrap gap-2 items-center" id="category-filter">
        <button
          data-category="all"
          class="filter-btn active rounded-full border border-blue-500/40 bg-blue-600/15 px-4 py-1.5 text-sm font-medium text-blue-300 transition-all"
        >
          All posts
        </button>
        {categories.map(cat => (
          <button
            data-category={cat}
            class="filter-btn rounded-full border border-slate-700/60 bg-slate-800/60 px-4 py-1.5 text-sm font-medium text-slate-400 hover:border-slate-600 hover:text-slate-300 transition-all"
          >
            {cat}
            <span class="ml-1 text-xs text-slate-600">({postsByCategory[cat]?.length ?? 0})</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Featured Posts -->
    {featuredPosts.length > 0 && (
      <section class="mb-12" id="featured-section">
        <h2 class="mb-6 text-sm font-semibold uppercase tracking-wider text-slate-500 flex items-center gap-2">
          <span class="h-px flex-1 bg-slate-800"></span>
          Featured
          <span class="h-px flex-1 bg-slate-800"></span>
        </h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredPosts.map(post => (
            <div data-category={post.data.category} class="post-item">
              <PostCard post={post} featured />
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- All Posts -->
    <section class="pb-20">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500 flex items-center gap-2">
          <span class="h-px w-8 bg-slate-800"></span>
          All Posts
        </h2>
        <span id="post-count" class="text-xs text-slate-600">{totalPosts} posts</span>
      </div>

      <div
        id="posts-grid"
        class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      >
        {allPosts.map(post => (
          <div data-category={post.data.category} class="post-item">
            <PostCard post={post} />
          </div>
        ))}
      </div>

      <p
        id="no-results"
        class="hidden text-center py-16 text-slate-500"
      >
        No posts found in this category.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const postItems = document.querySelectorAll<HTMLElement>('.post-item');
  const postCount = document.getElementById('post-count');
  const noResults = document.getElementById('no-results');
  const featuredSection = document.getElementById('featured-section');

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category ?? 'all';

      // Update button states
      filterButtons.forEach(b => {
        b.classList.remove('active', 'bg-blue-600/15', 'border-blue-500/40', 'text-blue-300');
        b.classList.add('bg-slate-800/60', 'border-slate-700/60', 'text-slate-400');
      });
      btn.classList.remove('bg-slate-800/60', 'border-slate-700/60', 'text-slate-400');
      btn.classList.add('active', 'bg-blue-600/15', 'border-blue-500/40', 'text-blue-300');

      // Filter posts
      let visible = 0;
      postItems.forEach(item => {
        const match = cat === 'all' || item.dataset.category === cat;
        item.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      if (postCount) postCount.textContent = `${visible} post${visible !== 1 ? 's' : ''}`;
      if (noResults) noResults.classList.toggle('hidden', visible > 0);

      // Hide/show featured section when filtering
      if (featuredSection) {
        featuredSection.style.display = cat === 'all' ? '' : 'none';
      }
    });
  });
</script>
