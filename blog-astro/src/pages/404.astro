---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="404 — Page Not Found" noindex>
  <Header />
  <main class="mx-auto max-w-xl px-4 py-32 text-center">
    <p class="text-8xl font-black text-slate-800 mb-4">404</p>
    <h1 class="text-2xl font-bold text-white mb-3">Page not found</h1>
    <p class="text-slate-400 mb-8">That page doesn't exist or was moved.</p>
    <a
      href="/"
      class="rounded-xl bg-blue-600 hover:bg-blue-500 px-6 py-3 text-sm font-semibold text-white transition-colors"
    >
      ← Back to Blog
    </a>
  </main>
  <Footer />
</BaseLayout>
