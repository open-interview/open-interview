modules = ["web", "python-3.12", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true
stack = "FULLSTACK_JS"
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"
packages = ["gh", "unzip", "lynx", "w3m", "iproute2", "nettools", "firefox", "vim", "mlocate", "tmux", "systemd", "containerd", "podman", "bubblewrap", "proot"]

[userenv]

[userenv.shared]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Blog preview"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development npx tsx server/index.ts"
waitForPort = 5000

[[workflows.workflow]]
name = "Blog preview"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @openinterview/blog run preview -- --port 3000 --host 0.0.0.0"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3333
externalPort = 4200

[[ports]]
localPort = 4096
externalPort = 6800
exposeLocalhost = true

[[ports]]
localPort = 4321
externalPort = 5000

[[ports]]
localPort = 4649
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 8080

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 5099
externalPort = 3003

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 6080
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 6000
exposeLocalhost = true

[[ports]]
localPort = 15900
externalPort = 8000

[[ports]]
localPort = 16080
externalPort = 8008
