---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map(post => {
    const relatedPosts = posts
      .filter(p => p.data.channel === post.data.channel && p.data.id !== post.data.id)
      .sort((a, b) => {
        const da = new Date(a.data.publishedAt ?? a.data.createdAt ?? 0).getTime();
        const db = new Date(b.data.publishedAt ?? b.data.createdAt ?? 0).getTime();
        return db - da;
      })
      .slice(0, 3)
      .map(p => ({
        id: p.data.id,
        slug: p.data.slug,
        title: p.data.title,
        channel: p.data.channel,
        difficulty: p.data.difficulty,
        excerpt: p.data.excerpt ?? '',
        readingTimeMinutes: p.data.readingTimeMinutes,
        tags: p.data.tags ?? [],
      }));

    return {
      params: { id: post.data.id, slug: post.data.slug },
      props: { post, relatedPosts },
    };
  });
}

const { post, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);
const d = post.data;

// Derive reading time from heading count when not set in frontmatter
// Technical deep-dives average ~2 min per heading section
const derivedReadingMins = d.readingTimeMinutes ?? Math.max(4, Math.round(headings.length * 1.8));
---
<BlogPost
  title={d.title}
  postId={d.id}
  slug={d.slug}
  channel={d.channel}
  difficulty={d.difficulty}
  tags={d.tags}
  createdAt={d.createdAt}
  publishedAt={d.publishedAt}
  funFact={d.funFact}
  diagram={d.diagram}
  images={d.images}
  sources={d.sources}
  author={d.author}
  excerpt={d.excerpt}
  readingTimeMinutes={derivedReadingMins}
  headings={headings}
  relatedPosts={relatedPosts}
>
  <Content />
</BlogPost>
