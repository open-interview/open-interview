---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ArticleCard from '../components/ArticleCard.astro';
import '../styles/global.css';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => {
    const da = new Date(a.data.publishedAt ?? a.data.createdAt ?? 0).getTime();
    const db = new Date(b.data.publishedAt ?? b.data.createdAt ?? 0).getTime();
    return db - da;
  });

// Stats
const total = posts.length;
const channels = [...new Set(posts.map(p => p.data.channel))].sort();
const difficulties = ['beginner', 'intermediate', 'advanced'];

// Channel post counts
const channelCounts: Record<string, number> = {};
posts.forEach(p => {
  channelCounts[p.data.channel] = (channelCounts[p.data.channel] ?? 0) + 1;
});
const topChannels = Object.entries(channelCounts)
  .sort((a, b) => b[1] - a[1])
  .map(([ch]) => ch);

// Derive word count estimate for read-time display on cards without readingTimeMinutes
const wordCounts: Record<string, number> = {};
for (const p of posts) {
  if (!p.data.readingTimeMinutes) {
    // Estimate from excerpt/funFact char count as a rough proxy (avg ~5 chars/word, article ~10x excerpt)
    const sample = (p.data.excerpt ?? p.data.funFact ?? '');
    wordCounts[p.data.id] = sample.length > 0 ? Math.max(800, sample.length * 10) : 1200;
  }
}

// Serialize posts for client-side filtering
const postsJson = posts.map(p => ({
  id: p.data.id,
  slug: p.data.slug,
  title: p.data.title,
  channel: p.data.channel,
  difficulty: p.data.difficulty ?? '',
  tags: p.data.tags ?? [],
  excerpt: (p.data.excerpt ?? '').substring(0, 200).replace(/\[\d+\]/g, ''),
  date: (p.data.publishedAt ?? p.data.createdAt)?.toISOString() ?? '',
  readingTimeMinutes: p.data.readingTimeMinutes ?? null,
  images: (p.data.images ?? []).slice(0, 1),
}));
---
<Layout
  title="DevInsights — Engineering Knowledge That Ships"
  description="Real-world engineering insights for developers building at scale. 150+ deep-dive articles on AWS, Kubernetes, DevOps, System Design, and more."
>
  <Header slot="header" activePath="/" />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>Engineering Knowledge<br/><span style="color:var(--accent)">That Ships</span></h1>
      <p>Deep-dive articles on distributed systems, cloud infrastructure, DevOps, and the engineering decisions that matter in production.</p>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-value" data-testid="stat-post-count">{total}</span>
          <span class="stat-label">Articles</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">{channels.length}</span>
          <span class="stat-label">Topics</span>
        </div>
        <div class="stat-item">
          <span class="stat-value">Free</span>
          <span class="stat-label">Always</span>
        </div>
      </div>
    </div>
  </section>

  <div class="container" style="padding-bottom:4rem">

    <!-- Filter bar -->
    <div class="filter-section">
      <div class="filter-row">
        <span class="filter-label">Search</span>
        <div class="search-filter-wrap" style="flex:1;max-width:400px">
          <svg class="search-filter-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            id="search-posts"
            type="search"
            class="search-filter-input"
            placeholder="Search by title, tag, channel…"
            autocomplete="off"
            data-testid="input-search-posts"
          />
        </div>
      </div>
      <div class="filter-row">
        <span class="filter-label">Topic</span>
        <button class="filter-btn active" data-filter-channel="all" data-testid="filter-channel-all">All</button>
        {topChannels.map(ch => (
          <button class="filter-btn" data-filter-channel={ch} data-channel={ch} data-testid={`filter-channel-${ch}`}>
            {ch} <span style="opacity:.6;font-weight:400">({channelCounts[ch]})</span>
          </button>
        ))}
      </div>
      <div class="filter-row">
        <span class="filter-label">Level</span>
        <button class="filter-btn active" data-filter-diff="all" data-testid="filter-diff-all">All</button>
        {difficulties.map(d => (
          <button class="filter-btn" data-filter-diff={d} data-testid={`filter-diff-${d}`}>{d}</button>
        ))}
      </div>
    </div>

    <!-- Results count -->
    <div class="section-header">
      <h2 class="section-title">Latest Articles</h2>
      <span class="section-count" id="results-count">{total} articles</span>
    </div>

    <!-- Articles grid -->
    <div class="cards-grid" id="posts-grid">
      {posts.map((post, i) => (
        <ArticleCard
          id={post.data.id}
          slug={post.data.slug}
          title={post.data.title}
          channel={post.data.channel}
          difficulty={post.data.difficulty}
          tags={post.data.tags}
          createdAt={post.data.createdAt}
          publishedAt={post.data.publishedAt}
          excerpt={post.data.excerpt}
          readingTimeMinutes={post.data.readingTimeMinutes}
          wordCount={wordCounts[post.data.id]}
          featured={i === 0}
          images={post.data.images}
        />
      ))}
    </div>

    <div class="no-results hidden" id="no-results">
      <p style="font-size:2rem">🔍</p>
      <p>No articles match your filters.</p>
      <p>Try a different search term or select a different topic.</p>
    </div>

  </div>
</Layout>

<script define:vars={{ postsJson }}>
  (function() {
    var posts = postsJson;
    var grid = document.getElementById('posts-grid');
    var noResults = document.getElementById('no-results');
    var countEl = document.getElementById('results-count');
    var searchInput = document.getElementById('search-posts');
    var channelBtns = document.querySelectorAll('[data-filter-channel]');
    var diffBtns = document.querySelectorAll('[data-filter-diff]');

    var activeChannel = 'all';
    var activeDiff = 'all';
    var searchQ = '';

    // Pre-read URL params
    var params = new URLSearchParams(window.location.search);
    if (params.get('q')) {
      searchQ = params.get('q');
      if (searchInput) searchInput.value = searchQ;
    }

    function matches(p) {
      if (activeChannel !== 'all' && p.channel !== activeChannel) return false;
      if (activeDiff !== 'all' && p.difficulty !== activeDiff) return false;
      if (searchQ) {
        var q = searchQ.toLowerCase();
        var text = (p.title + ' ' + p.channel + ' ' + (p.excerpt || '') + ' ' + (p.tags || []).join(' ')).toLowerCase();
        if (!text.includes(q)) return false;
      }
      return true;
    }

    function render() {
      var cards = grid ? Array.from(grid.querySelectorAll('.article-card')) : [];
      var visible = 0;
      cards.forEach(function(card) {
        var testId = card.getAttribute('data-testid') || '';
        var id = testId.replace('card-article-', '');
        var post = posts.find(function(p) { return p.id === id; });
        var show = post ? matches(post) : true;
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });
      if (countEl) countEl.textContent = visible + ' article' + (visible !== 1 ? 's' : '');
      if (noResults) noResults.classList.toggle('hidden', visible > 0);
    }

    channelBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeChannel = btn.dataset.filterChannel;
        channelBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.filterChannel === activeChannel); });
        render();
      });
    });
    diffBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        activeDiff = btn.dataset.filterDiff;
        diffBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.filterDiff === activeDiff); });
        render();
      });
    });
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        searchQ = searchInput.value.trim();
        render();
      });
    }

    render();
  })();
</script>
