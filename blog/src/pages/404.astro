---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';
---
<Layout title="Page Not Found — DevInsights" description="The page you are looking for does not exist.">
  <Header slot="header" />
  <div class="container">
    <div class="error-page">
      <div class="error-code">404</div>
      <h1 class="error-title">Page not found</h1>
      <p class="error-desc">The article or page you're looking for doesn't exist or may have moved.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;justify-content:center">
        <a href="/" class="cta-btn">Browse all articles</a>
        <a href="/channels/" class="outline-btn">View topics</a>
      </div>
    </div>
  </div>
</Layout>
