---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import '../../styles/global.css';

const allPosts = await getCollection('blog');

// Build channel stats
const channelMap: Record<string, number> = {};
allPosts.forEach(p => {
  const ch = p.data.channel;
  channelMap[ch] = (channelMap[ch] ?? 0) + 1;
});
const channels = Object.entries(channelMap)
  .sort((a, b) => b[1] - a[1])
  .map(([ch, count]) => ({ ch, count }));

const channelIcons: Record<string, string> = {
  aws: '☁️', kubernetes: '⚙️', docker: '🐳', devops: '🔄',
  terraform: '🏗️', security: '🔒', sre: '📊', linux: '🐧',
  unix: '🐧', networking: '🌐', 'machine-learning': '🤖', ai: '🤖',
  ml: '🤖', backend: '⚡', frontend: '🎨', database: '🗄️',
  databases: '🗄️', 'system-design': '🏛️', monitoring: '📈',
  observability: '👁️', cloud: '☁️', microservices: '🧩', testing: '🧪',
};
---
<Layout
  title="All Topics — DevInsights"
  description={`Browse all ${channels.length} engineering topics covered on DevInsights.`}
>
  <Header slot="header" activePath="/channels/" />

  <div class="container" style="padding:3rem 1.5rem 4rem">
    <div style="margin-bottom:2rem">
      <h1 style="margin-bottom:.5rem">Browse by Topic</h1>
      <p style="color:var(--fg-2)">{channels.length} topics · {allPosts.length} articles total</p>
    </div>

    <div class="channels-grid">
      {channels.map(({ ch, count }) => (
        <a href={`/channels/${ch}/`} class="channel-card" data-channel={ch} data-testid={`link-channel-${ch}`}>
          <span class="channel-icon">{channelIcons[ch] ?? '📖'}</span>
          <div class="channel-name">{ch.replace(/-/g, ' ')}</div>
          <div class="channel-count">{count} article{count !== 1 ? 's' : ''}</div>
        </a>
      ))}
    </div>
  </div>
</Layout>
