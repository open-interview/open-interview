---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';

function decodeEntities(str: string): string {
  return str
    .replace(/&quot;/g, '"').replace(/&apos;/g, "'")
    .replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>');
}

interface ImageItem { url: string; alt?: string; caption?: string; placement?: string; }
interface SourceItem { title: string; url: string; type?: string; }
interface Heading { depth: number; text: string; slug: string; }
interface RelatedPost {
  id: string; slug: string; title: string; channel: string;
  difficulty?: string; excerpt?: string; readingTimeMinutes?: number; tags?: string[];
}
interface Props {
  title: string; slug: string; channel: string; difficulty?: string; tags?: string[];
  createdAt?: Date; publishedAt?: Date; funFact?: string; diagram?: string;
  images?: ImageItem[]; sources?: SourceItem[]; author?: string; excerpt?: string;
  readingTimeMinutes?: number; headings: Heading[]; postId: string; relatedPosts?: RelatedPost[];
}
const {
  title, slug, channel, difficulty, tags = [],
  createdAt, publishedAt, funFact, diagram,
  images = [], sources = [], author, excerpt,
  readingTimeMinutes, headings, postId, relatedPosts = [],
} = Astro.props;

const pubDate = publishedAt ?? createdAt;
const dateStr = pubDate
  ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://open-interview.github.io';
const postUrl = `${site}/posts/${postId}/${slug}/`;

// Prefer external images (local /images/ paths may not be deployed yet)
const externalImages = images.filter(i => i.url.startsWith('http'));
const allImages = externalImages.length > 0 ? externalImages : images;

const coverImg = allImages.find(i => i.placement === 'after-intro')
  ?? allImages.find(i => i.url.includes('illustrations.'))
  ?? allImages[0];

const midImages = allImages.filter(
  i => i.placement === 'mid-content' || i.placement === 'after-section-2'
);

const hasDiagram = Boolean(diagram?.trim());
const diagramCode = diagram?.replace(/\\n/g, '\n') ?? '';

function getDiagramLabel(code: string): string {
  if (!code) return 'Architecture Diagram';
  const first = code.trim().split('\n')[0].toLowerCase();
  if (first.startsWith('flowchart') || first.startsWith('graph')) return 'Flow Diagram';
  if (first.startsWith('sequencediagram')) return 'Sequence Diagram';
  if (first.startsWith('classdiagram') || first.startsWith('class')) return 'Class Diagram';
  if (first.startsWith('erdiagram') || first.startsWith('er')) return 'ER Diagram';
  if (first.startsWith('statediagram')) return 'State Diagram';
  if (first.startsWith('gantt')) return 'Gantt Chart';
  return 'Architecture Diagram';
}
const diagramLabel = getDiagramLabel(diagram ?? '');

const tocHeadings = headings.filter(h => h.depth <= 3);

const jsonLd = {
  '@context': 'https://schema.org', '@type': 'TechArticle',
  headline: title,
  description: excerpt || funFact?.substring(0, 160) || title,
  url: postUrl,
  datePublished: pubDate?.toISOString(),
  author: { '@type': 'Organization', name: author ?? 'DevInsights' },
  publisher: { '@type': 'Organization', name: 'DevInsights', url: site },
  keywords: tags.join(', '), articleSection: channel,
  ...(coverImg && { image: { '@type': 'ImageObject', url: coverImg.url.startsWith('http') ? coverImg.url : `${site}${coverImg.url}` } }),
};

const authorInitials = (author ?? 'D').substring(0, 1).toUpperCase();
---
<Layout
  title={`${title} | DevInsights`}
  description={excerpt || funFact?.substring(0, 160) || title}
  ogImage={coverImg?.url}
  pubDate={pubDate}
  channel={channel}
  tags={tags}
  jsonLd={jsonLd}
  includeMermaid={hasDiagram}
>
  <div id="progress-bar" slot="progress" role="progressbar" aria-valuemin={0} aria-valuemax={100}></div>
  <Header slot="header" />

  <div class="article-outer container">
    <article class="article-main" data-channel={channel}>

      <!-- Back link -->
      <a href="/" class="back-link" data-testid="link-back-to-blog">← Back to Blog</a>

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href="/">Blog</a>
        <span class="bc-sep">›</span>
        <a href={`/channels/${channel}/`}>{channel}</a>
        <span class="bc-sep">›</span>
        <span>{title.substring(0, 45)}{title.length > 45 ? '…' : ''}</span>
      </nav>

      <!-- Header -->
      <header class="article-header">
        <div class="badge-row">
          <span class="badge channel-badge" data-channel={channel}>{channel}</span>
          {difficulty && <span class="badge difficulty-badge" data-difficulty={difficulty}>{difficulty}</span>}
          {readingTimeMinutes && (
            <span class="badge read-badge">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              {readingTimeMinutes} min read
            </span>
          )}
        </div>

        <h1 class="article-title">{title}</h1>

        <div class="article-meta-row">
          <div class="author-avatar" aria-hidden="true">{authorInitials}</div>
          <div class="meta-info">
            <span class="meta-author">{author ?? 'DevInsights'}</span>
            {dateStr && (
              <>
                <span class="meta-sep">·</span>
                <time class="meta-date" datetime={pubDate?.toISOString()}>{dateStr}</time>
              </>
            )}
          </div>
          {tags.length > 0 && (
            <div class="article-tags" aria-label="Tags">
              {tags.slice(0, 4).map(t => <span class="tag">#{t}</span>)}
            </div>
          )}
        </div>

        <!-- Inline share row -->
        <div class="article-share-row">
          <a class="share-inline-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`} target="_blank" rel="noopener" aria-label="Share on Twitter" data-testid="link-share-twitter">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Twitter
          </a>
          <a class="share-inline-btn" href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener" aria-label="Share on LinkedIn" data-testid="link-share-linkedin">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <button class="share-inline-btn" id="copy-link-btn" data-url={postUrl} data-testid="button-copy-link">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Copy link
          </button>
        </div>
        <hr class="article-divider" />
      </header>

      <!-- Inline TOC (collapsible) -->
      {tocHeadings.length > 2 && (
        <details class="toc-inline" id="toc-inline">
          <summary class="toc-inline-toggle">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
            Contents ({tocHeadings.length} sections)
          </summary>
          <nav aria-label="Table of contents">
            <ol class="toc-inline-list">
              {tocHeadings.map(h => (
                <li class={`toc-item depth-${h.depth}`}>
                  <a href={`#${h.slug}`}>{decodeEntities(h.text)}</a>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      )}

      <!-- Cover image — onerror hides the figure so broken local paths fail silently -->
      {coverImg && (
        <figure class="article-cover" id="cover-fig">
          <img
            src={coverImg.url}
            alt={coverImg.alt || title}
            loading="eager"
            onerror="this.closest('figure').style.display='none'"
          />
          {coverImg.caption && <figcaption>{coverImg.caption}</figcaption>}
        </figure>
      )}

      <!-- Fun fact callout -->
      {funFact && (
        <div class="fun-fact">
          <span class="fun-fact-icon">💡</span>
          <p class="fun-fact-text"><strong>Fun fact:</strong> {decodeEntities(funFact.replace(/\[\d+\]/g, ''))}</p>
        </div>
      )}

      <!-- Body -->
      <div class="article-body">
        <slot />
      </div>

      <!-- Mid-content images -->
      {midImages.length > 0 && (
        <div class="mid-images">
          {midImages.map(img => (
            <figure class="article-img">
              <img src={img.url} alt={img.alt || ''} loading="lazy" onerror="this.closest('figure').style.display='none'" />
              {img.caption && <figcaption>{img.caption}</figcaption>}
            </figure>
          ))}
        </div>
      )}

      <!-- Architecture Diagram -->
      {hasDiagram && (
        <section class="diagram-section">
          <h2 class="diagram-title">{diagramLabel}</h2>
          <div class="mermaid-wrap" data-label={diagramLabel}>
            <div class="mermaid">{diagramCode}</div>
          </div>
        </section>
      )}

      <!-- Sources -->
      {sources.length > 0 && (
        <section class="sources-section">
          <h2>References</h2>
          <ol class="sources-list">
            {sources.map((src, i) => (
              <li>
                <span class="source-num">{i + 1}</span>
                <a href={src.url} class="source-link" target="_blank" rel="noopener noreferrer">{src.title}</a>
                {src.type && <span class="source-type">{src.type}</span>}
              </li>
            ))}
          </ol>
        </section>
      )}

      <!-- Related Articles -->
      {relatedPosts.length > 0 && (
        <section class="related-posts">
          <h2 class="related-title">More in <span style="text-transform:capitalize">{channel.replace(/-/g, ' ')}</span></h2>
          <div class="related-grid">
            {relatedPosts.map(p => (
              <a href={`/posts/${p.id}/${p.slug}/`} class="related-card" data-channel={p.channel}>
                <div class="related-card-meta">
                  {p.difficulty && <span class="badge difficulty-badge" data-difficulty={p.difficulty}>{p.difficulty}</span>}
                  {p.readingTimeMinutes && <span class="read-time">⏱ {p.readingTimeMinutes} min</span>}
                </div>
                <h3>{p.title}</h3>
                {p.excerpt && <p class="related-excerpt">{p.excerpt.substring(0, 110)}{p.excerpt.length > 110 ? '…' : ''}</p>}
                {p.tags && p.tags.length > 0 && (
                  <div class="card-tags" style="margin-top:auto;padding-top:.5rem">
                    {p.tags.slice(0, 2).map(t => <span class="tag">#{t}</span>)}
                  </div>
                )}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Back link footer -->
      <div class="article-footer">
        <a href="/" class="outline-btn">← Back to all posts</a>
      </div>

    </article>
  </div>

  <!-- Floating share panel (right side, fixed) -->
  <aside class="share-float" id="share-float" aria-label="Share options">
    <a class="share-float-btn" id="sf-twitter"
      href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`}
      target="_blank" rel="noopener" aria-label="Share on Twitter" data-testid="link-float-twitter">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a class="share-float-btn" id="sf-linkedin"
      href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(title)}`}
      target="_blank" rel="noopener" aria-label="Share on LinkedIn" data-testid="link-float-linkedin">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
    <button class="share-float-btn" id="sf-copy" data-url={postUrl} aria-label="Copy link" data-testid="button-float-copy">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    </button>
    <div class="share-float-divider"></div>
    <button class="share-float-btn" id="sf-print" aria-label="Print" data-testid="button-float-print" onclick="window.print()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
    </button>
    <button class="share-float-btn" id="sf-bookmark" aria-label="Bookmark" data-testid="button-float-bookmark">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
    </button>
  </aside>

  <!-- Back to top -->
  <button id="back-to-top" aria-label="Back to top" data-testid="button-back-to-top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 15l-6-6-6 6"/></svg>
  </button>
</Layout>

<script is:inline>
  (function() {

    /* Reading progress bar */
    var bar = document.getElementById('progress-bar');
    if (bar) {
      function updateBar() {
        var scrolled = document.documentElement.scrollTop;
        var total = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
      }
      window.addEventListener('scroll', updateBar, { passive: true });
      updateBar();
    }

    /* Back to top */
    var btn = document.getElementById('back-to-top');
    if (btn) {
      window.addEventListener('scroll', function() {
        btn.classList.toggle('visible', window.scrollY > 400);
      }, { passive: true });
      btn.addEventListener('click', function() { window.scrollTo({ top: 0, behavior: 'smooth' }); });
    }

    /* Floating share panel: show after 200px scroll */
    var floatPanel = document.getElementById('share-float');
    if (floatPanel) {
      window.addEventListener('scroll', function() {
        floatPanel.classList.toggle('visible', window.scrollY > 200);
      }, { passive: true });
    }

    /* Copy link — inline button */
    var copyBtn = document.getElementById('copy-link-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(copyBtn.dataset.url || location.href).then(function() {
          var prev = copyBtn.innerHTML;
          copyBtn.textContent = '✓ Copied!';
          setTimeout(function() { copyBtn.innerHTML = prev; }, 2000);
        });
      });
    }

    /* Copy link — float button */
    var sfCopy = document.getElementById('sf-copy');
    if (sfCopy) {
      sfCopy.addEventListener('click', function() {
        navigator.clipboard.writeText(sfCopy.dataset.url || location.href).then(function() {
          sfCopy.classList.add('copied');
          setTimeout(function() { sfCopy.classList.remove('copied'); }, 2000);
        });
      });
    }

    /* Bookmark toggle */
    var sfBookmark = document.getElementById('sf-bookmark');
    if (sfBookmark) {
      var bKey = 'bm_' + location.pathname;
      if (localStorage.getItem(bKey)) sfBookmark.classList.add('active');
      sfBookmark.addEventListener('click', function() {
        if (localStorage.getItem(bKey)) {
          localStorage.removeItem(bKey);
          sfBookmark.classList.remove('active');
        } else {
          localStorage.setItem(bKey, '1');
          sfBookmark.classList.add('active');
        }
      });
    }

    /* Code block copy buttons */
    var body = document.querySelector('.article-body');
    if (body) {
      body.querySelectorAll('pre').forEach(function(pre) {
        var wrap = document.createElement('div');
        wrap.className = 'code-block-wrap';
        pre.parentNode.insertBefore(wrap, pre);
        wrap.appendChild(pre);

        /* Language label */
        var code = pre.querySelector('code');
        if (code) {
          var cls = code.className || '';
          var m = cls.match(/language-(\w+)/);
          if (m) pre.setAttribute('data-lang', m[1]);
        }

        var copyB = document.createElement('button');
        copyB.className = 'copy-btn';
        copyB.textContent = 'Copy';
        copyB.setAttribute('aria-label', 'Copy code');
        wrap.appendChild(copyB);
        copyB.addEventListener('click', function() {
          var text = pre.querySelector('code') ? pre.querySelector('code').innerText : pre.innerText;
          navigator.clipboard.writeText(text).then(function() {
            copyB.textContent = 'Copied!';
            copyB.classList.add('copied');
            setTimeout(function() { copyB.textContent = 'Copy'; copyB.classList.remove('copied'); }, 2000);
          });
        });
      });

      /* Heading anchor links */
      body.querySelectorAll('h2, h3, h4').forEach(function(h) {
        if (!h.id) return;
        var a = document.createElement('a');
        a.className = 'anchor';
        a.href = '#' + h.id;
        a.setAttribute('aria-label', 'Link to section');
        a.textContent = '#';
        h.appendChild(a);
      });
    }

    /* TOC scroll spy (inline TOC) */
    var tocList = document.querySelector('.toc-inline-list');
    if (tocList) {
      var tocItems = Array.from(tocList.querySelectorAll('[data-slug]'));
      var tocLinks = Array.from(tocList.querySelectorAll('a[href^="#"]'));
      var headingEls = tocLinks.map(function(a) {
        var id = a.getAttribute('href').slice(1);
        return document.getElementById(id);
      }).filter(Boolean);

      if (headingEls.length) {
        var activeId = null;
        function setActive(id) {
          if (id === activeId) return;
          tocLinks.forEach(function(a) { a.classList.remove('active'); });
          activeId = id;
          tocLinks.forEach(function(a) {
            if (a.getAttribute('href') === '#' + id) a.classList.add('active');
          });
        }
        window.addEventListener('scroll', function() {
          var scrollY = window.scrollY + 90;
          var cur = headingEls[0];
          headingEls.forEach(function(el) {
            if (el.getBoundingClientRect().top + window.scrollY <= scrollY) cur = el;
          });
          if (cur) setActive(cur.id);
        }, { passive: true });
      }
    }

  })();
</script>
