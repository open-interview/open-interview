---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import '../styles/global.css';

interface ImageItem {
  url: string;
  alt?: string;
  caption?: string;
  placement?: string;
}
interface SourceItem {
  title: string;
  url: string;
  type?: string;
}
interface Heading { depth: number; text: string; slug: string; }
interface Props {
  title: string;
  slug: string;
  channel: string;
  difficulty?: string;
  tags?: string[];
  createdAt?: Date;
  publishedAt?: Date;
  funFact?: string;
  diagram?: string;
  images?: ImageItem[];
  sources?: SourceItem[];
  author?: string;
  excerpt?: string;
  readingTimeMinutes?: number;
  headings: Heading[];
  postId: string;
}
const {
  title, slug, channel, difficulty, tags = [],
  createdAt, publishedAt, funFact, diagram,
  images = [], sources = [], author, excerpt,
  readingTimeMinutes, headings, postId,
} = Astro.props;

const pubDate = publishedAt ?? createdAt;
const dateStr = pubDate
  ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://open-interview.github.io';
const postUrl = `${site}/posts/${postId}/${slug}/`;
const coverImg = images.find(i => i.placement === 'after-intro') ?? images.find(i => i.url.startsWith('https://illustrations.')) ?? images[0];
const midImages = images.filter(i => i.placement === 'mid-content' || i.placement === 'after-section-2');
const hasDiagram = Boolean(diagram?.trim());

// Detect diagram type for label
function getDiagramLabel(code: string): string {
  if (!code) return 'Architecture Diagram';
  const first = code.trim().split('\n')[0].toLowerCase();
  if (first.startsWith('flowchart') || first.startsWith('graph')) return 'Flow Diagram';
  if (first.startsWith('sequencediagram')) return 'Sequence Diagram';
  if (first.startsWith('classDiagram') || first.startsWith('class')) return 'Class Diagram';
  if (first.startsWith('erDiagram') || first.startsWith('er')) return 'ER Diagram';
  if (first.startsWith('stateDiagram')) return 'State Diagram';
  if (first.startsWith('gantt')) return 'Gantt Chart';
  return 'Architecture Diagram';
}
const diagramLabel = getDiagramLabel(diagram ?? '');

// JSON-LD
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: excerpt || funFact?.substring(0, 160) || title,
  url: postUrl,
  datePublished: pubDate?.toISOString(),
  author: { '@type': 'Organization', name: author ?? 'DevInsights' },
  publisher: {
    '@type': 'Organization',
    name: 'DevInsights',
    url: site,
  },
  keywords: tags.join(', '),
  articleSection: channel,
  ...(coverImg && { image: { '@type': 'ImageObject', url: coverImg.url.startsWith('http') ? coverImg.url : `${site}${coverImg.url}` } }),
};

// Normalize mermaid diagram (handle literal \n in stored strings)
const diagramCode = diagram?.replace(/\\n/g, '\n') ?? '';
---
<Layout
  title={`${title} | DevInsights`}
  description={excerpt || funFact?.substring(0, 160) || title}
  ogImage={coverImg?.url}
  pubDate={pubDate}
  channel={channel}
  tags={tags}
  jsonLd={jsonLd}
  includeMermaid={hasDiagram}
>
  <div id="progress-bar" slot="progress" role="progressbar" aria-valuemin={0} aria-valuemax={100}></div>
  <Header slot="header" />

  <div class="container">
    <div class="article-layout" data-channel={channel}>

      <!-- TOC sidebar (left) -->
      <TableOfContents headings={headings} />

      <!-- Main content -->
      <article class="article-main">

        <!-- Header -->
        <header class="article-header">
          <div class="breadcrumb">
            <a href="/">Home</a> /
            <a href="/channels/">{channel}</a> /
            <span>{title.substring(0, 40)}{title.length > 40 ? '…' : ''}</span>
          </div>

          <div class="badge-row">
            <span class="badge channel-badge" data-channel={channel}>{channel}</span>
            {difficulty && <span class="badge difficulty-badge" data-difficulty={difficulty}>{difficulty}</span>}
            {readingTimeMinutes && (
              <span class="badge" style="border:1px solid var(--border);color:var(--fg-2);background:var(--bg-2);">
                ⏱ {readingTimeMinutes} min read
              </span>
            )}
          </div>

          <h1 class="article-title">{title}</h1>

          <div class="article-meta">
            {dateStr && (
              <time datetime={pubDate?.toISOString()}>{dateStr}</time>
            )}
            {author && <><span class="sep">·</span><span>By {author}</span></>}
            {tags.length > 0 && (
              <>
                <span class="sep">·</span>
                <div class="card-tags" style="margin:0">
                  {tags.slice(0, 5).map(t => <span class="tag">#{t}</span>)}
                </div>
              </>
            )}
          </div>
        </header>

        <!-- Cover image -->
        {coverImg && (
          <figure class="article-cover">
            <img src={coverImg.url} alt={coverImg.alt || title} loading="eager" />
          </figure>
        )}

        <!-- Fun fact callout -->
        {funFact && (
          <div class="fun-fact">
            <span class="fun-fact-icon">💡</span>
            <p class="fun-fact-text"><strong>Fun fact:</strong> {funFact.replace(/\[\d+\]/g, '')}</p>
          </div>
        )}

        <!-- Body -->
        <div class="article-body">
          <slot />
        </div>

        <!-- Mid-content images (after body) -->
        {midImages.length > 0 && (
          <div style="margin:2rem 0;">
            {midImages.map(img => (
              <figure class="article-img">
                <img src={img.url} alt={img.alt || ''} loading="lazy" />
                {img.caption && <figcaption>{img.caption}</figcaption>}
              </figure>
            ))}
          </div>
        )}

        <!-- Architecture Diagram from frontmatter -->
        {hasDiagram && (
          <section style="margin:2.5rem 0;">
            <h2 style="margin-bottom:1rem">{diagramLabel}</h2>
            <div class="mermaid-wrap" data-label={diagramLabel}>
              <div class="mermaid">{diagramCode}</div>
            </div>
          </section>
        )}

        <!-- Sources -->
        {sources.length > 0 && (
          <section class="sources-section">
            <h2>References</h2>
            <ol class="sources-list">
              {sources.map((src, i) => (
                <li>
                  <span class="source-num">{i + 1}</span>
                  <a href={src.url} class="source-link" target="_blank" rel="noopener noreferrer">
                    {src.title}
                  </a>
                  {src.type && <span class="source-type">{src.type}</span>}
                </li>
              ))}
            </ol>
          </section>
        )}

        <!-- Share -->
        <div class="share-section">
          <span class="share-label">Share this article</span>
          <div class="share-buttons">
            <a
              class="share-btn"
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(postUrl)}`}
              target="_blank" rel="noopener"
            >
              𝕏 Twitter
            </a>
            <a
              class="share-btn"
              href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(postUrl)}&title=${encodeURIComponent(title)}`}
              target="_blank" rel="noopener"
            >
              LinkedIn
            </a>
            <button class="share-btn" id="copy-link-btn" data-url={postUrl} data-testid="button-copy-link">
              Copy Link
            </button>
          </div>
        </div>

        <!-- Back link -->
        <div style="margin-top:2rem;text-align:center;">
          <a href="/" class="outline-btn">← Back to all posts</a>
        </div>

      </article>
    </div>
  </div>
</Layout>

<script is:inline>
  /* Reading progress bar */
  (function() {
    var bar = document.getElementById('progress-bar');
    if (!bar) return;
    function update() {
      var scrolled = document.documentElement.scrollTop;
      var total = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      bar.style.width = (total > 0 ? (scrolled / total) * 100 : 0) + '%';
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  })();

  /* Copy link button */
  (function() {
    var btn = document.getElementById('copy-link-btn');
    if (!btn) return;
    btn.addEventListener('click', function() {
      navigator.clipboard.writeText(btn.dataset.url || location.href).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy Link'; }, 2000);
      });
    });
  })();
</script>
