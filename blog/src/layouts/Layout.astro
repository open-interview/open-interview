---
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  jsonLd?: Record<string, unknown>;
  includeMermaid?: boolean;
  pubDate?: Date;
  channel?: string;
  tags?: string[];
}
const {
  title,
  description = 'Real-world engineering insights for developers building at scale.',
  ogImage,
  canonicalURL,
  jsonLd,
  includeMermaid = false,
  pubDate,
  channel,
  tags = [],
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://open-interview.github.io';
const canonical = canonicalURL ?? new URL(Astro.url.pathname, Astro.site).toString();
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? 'G-47MSM57H95';
---
<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title="DevInsights RSS" href={`${site}/feed.xml`} />

  <!-- Open Graph -->
  <meta property="og:type" content={pubDate ? 'article' : 'website'} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="DevInsights" />
  {ogImage && <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `${site}${ogImage}`} />}
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  {channel && <meta property="article:section" content={channel} />}
  {tags.map(t => <meta property="article:tag" content={t} />)}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImage && <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `${site}${ogImage}`} />}

  <!-- JSON-LD -->
  {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" /></noscript>

  <!-- Theme: set before paint to avoid flash -->
  <script is:inline>
    (function(){
      const stored = localStorage.getItem('theme');
      const pref = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', stored || pref);
    })();
  </script>

  <slot name="head" />

  <!-- Mermaid (only on pages that need it) -->
  {includeMermaid && (
    <>
      <script is:inline defer src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
      <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
          if (window.mermaid) {
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            mermaid.initialize({
              startOnLoad: true,
              theme: isDark ? 'dark' : 'base',
              themeVariables: isDark ? {
                primaryColor: '#1f3a5c',
                primaryTextColor: '#e6edf3',
                primaryBorderColor: '#58a6ff',
                lineColor: '#58a6ff',
                secondaryColor: '#21262d',
                tertiaryColor: '#161b22',
                background: '#0d1117',
                mainBkg: '#161b22',
                nodeTextColor: '#e6edf3',
                fontSize: '15px'
              } : {
                primaryColor: '#ddf4ff',
                primaryTextColor: '#1f2328',
                primaryBorderColor: '#0969da',
                lineColor: '#0969da',
                background: '#ffffff',
                mainBkg: '#f6f8fa',
                fontSize: '15px'
              },
              flowchart: { curve: 'basis', padding: 20, htmlLabels: true, useMaxWidth: true }
            });
          }
        });
      </script>
    </>
  )}

  <!-- GA4 -->
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script is:inline define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_ID, { anonymize_ip: true });
  </script>
</head>
<body>
  <slot name="progress" />
  <slot name="header" />
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="/channels/">Topics</a>
        <a href="/feed.xml">RSS Feed</a>
        <a href="https://open-interview.github.io" target="_blank" rel="noopener">Open Interview</a>
      </div>
      <span class="footer-copy">© {new Date().getFullYear()} DevInsights · Built with Astro</span>
    </div>
  </footer>
</body>
</html>
