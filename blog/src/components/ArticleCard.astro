---
interface ImageItem {
  url: string;
  alt?: string;
  caption?: string;
  placement?: string;
}
interface Props {
  id: string;
  slug: string;
  title: string;
  channel: string;
  difficulty?: string;
  tags?: string[];
  createdAt?: Date;
  publishedAt?: Date;
  excerpt?: string;
  funFact?: string;
  readingTimeMinutes?: number;
  featured?: boolean;
  images?: ImageItem[];
}
const {
  id, slug, title, channel, difficulty, tags = [],
  createdAt, publishedAt, excerpt, funFact, readingTimeMinutes, featured = false, images = [],
} = Astro.props;

const postUrl = `/posts/${id}/${slug}/`;
const date = (publishedAt ?? createdAt);
const dateStr = date
  ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : '';
const coverImg = images.find(i => i.placement === 'after-intro') ?? images[0];
const desc = excerpt ?? funFact ?? '';
---
<article class:list={['article-card', featured && 'featured']} data-channel={channel} data-testid={`card-article-${id}`}>
  {coverImg && (
    <a href={postUrl} class="card-image" aria-hidden="true" tabindex="-1">
      <img src={coverImg.url} alt={coverImg.alt || title} loading="lazy" width="400" height="225" />
    </a>
  )}
  <div class="card-body">
    <div class="card-meta">
      <span class="badge channel-badge" data-channel={channel}>{channel}</span>
      {difficulty && <span class="badge difficulty-badge" data-difficulty={difficulty}>{difficulty}</span>}
      {readingTimeMinutes && <span class="read-time">⏱ {readingTimeMinutes} min</span>}
    </div>
    <h2 class="card-title">
      <a href={postUrl} data-testid={`link-post-${id}`}>{title}</a>
    </h2>
    {desc && <p class="card-excerpt">{desc.replace(/\[\d+\]/g, '')}</p>}
    <div class="card-footer">
      {dateStr && <time datetime={date?.toISOString()}>{dateStr}</time>}
      {tags.length > 0 && (
        <div class="card-tags">
          {tags.slice(0, 3).map(t => <span class="tag">#{t}</span>)}
        </div>
      )}
    </div>
  </div>
</article>
