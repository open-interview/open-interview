---
interface Heading {
  depth: number;
  text: string;
  slug: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 4);
---
{filtered.length > 2 && (
  <aside class="toc-sidebar" aria-label="Table of contents">
    <nav class="toc-sticky">
      <p class="toc-title">On this page</p>
      <ul class="toc-list" id="toc-list">
        {filtered.map(h => (
          <li class={`toc-item depth-${h.depth}`} data-slug={h.slug}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script is:inline>
  (function() {
    var list = document.getElementById('toc-list');
    if (!list) return;
    var items = Array.from(list.querySelectorAll('[data-slug]'));
    var headingEls = items.map(function(li) {
      return document.getElementById(li.dataset.slug);
    }).filter(Boolean);
    if (!headingEls.length) return;
    var activeId = null;

    function setActive(id) {
      if (id === activeId) return;
      // Clear previous
      if (activeId) {
        var prev = list.querySelector('[data-slug="' + activeId + '"]');
        if (prev) prev.classList.remove('active');
      }
      activeId = id;
      var next = list.querySelector('[data-slug="' + id + '"]');
      if (next) {
        next.classList.add('active');
        // Scroll the TOC sidebar so active item stays visible
        var nav = list.closest('.toc-sticky');
        if (nav) {
          var itemTop = next.offsetTop;
          var itemBot = itemTop + next.offsetHeight;
          var navTop = nav.scrollTop;
          var navBot = navTop + nav.clientHeight;
          if (itemTop < navTop + 20) {
            nav.scrollTo({ top: itemTop - 24, behavior: 'smooth' });
          } else if (itemBot > navBot - 20) {
            nav.scrollTo({ top: itemBot - nav.clientHeight + 24, behavior: 'smooth' });
          }
        }
      }
    }

    function onScroll() {
      var scrollY = window.scrollY + 90;
      var current = headingEls[0];
      for (var i = 0; i < headingEls.length; i++) {
        if (headingEls[i].getBoundingClientRect().top + window.scrollY <= scrollY) {
          current = headingEls[i];
        }
      }
      if (current) setActive(current.id);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
