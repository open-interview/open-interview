---
interface Heading {
  depth: number;
  text: string;
  slug: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 4);
---
{filtered.length > 2 && (
  <aside class="toc-sidebar" aria-label="Table of contents">
    <nav class="toc-sticky">
      <p class="toc-title">On this page</p>
      <ul class="toc-list" id="toc-list">
        {filtered.map(h => (
          <li class={`toc-item depth-${h.depth}`} data-slug={h.slug}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<script is:inline>
  (function() {
    var list = document.getElementById('toc-list');
    if (!list) return;
    var items = Array.from(list.querySelectorAll('[data-slug]'));
    var headingEls = items.map(function(li) {
      return document.getElementById(li.dataset.slug);
    }).filter(Boolean);
    if (!headingEls.length) return;
    var active = null;
    function onScroll() {
      var scrollY = window.scrollY + 100;
      var current = headingEls[0];
      for (var i = 0; i < headingEls.length; i++) {
        if (headingEls[i].offsetTop <= scrollY) current = headingEls[i];
      }
      if (current && current !== active) {
        if (active) {
          var prev = list.querySelector('[data-slug="' + active.id + '"]');
          if (prev) prev.classList.remove('active');
        }
        active = current;
        var next = list.querySelector('[data-slug="' + active.id + '"]');
        if (next) next.classList.add('active');
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
