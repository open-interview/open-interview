# OpenRouter Cookie Authentication
# Get this from your browser after logging into https://openrouter.ai
# Run: node script/get-openrouter-cookie.js for help
VITE_OPENROUTER_COOKIE=""

# SQLite Database Configuration
# Path to the local SQLite database file
SQLITE_URL="file:local.db"
SQLITE_AUTH_TOKEN=""

# Giscus Configuration (for GitHub Discussions integration)
# Get these values from https://giscus.app after setting up your repo
VITE_GISCUS_REPO="open-interview/open-interview.github.io"
VITE_GISCUS_REPO_ID="R_kgDOQuSz7g"
VITE_GISCUS_CATEGORY="General"
VITE_GISCUS_CATEGORY_ID="DIC_kwDOQuSz7s4C0NCw"

# GitHub Repository for Issue Creation
# Repository where feedback issues should be created
VITE_GITHUB_REPO="open-interview/open-interview"

# Google Analytics (for blog and main app)
# Get your GA4 Measurement ID from https://analytics.google.com
# The main app uses VITE_GA_MEASUREMENT_ID, blog uses GA_MEASUREMENT_ID
# Default: G-47MSM57H95 (Open Interview GA4 property)
GA_MEASUREMENT_ID="G-47MSM57H95"
VITE_GA_MEASUREMENT_ID="G-47MSM57H95"

# Qdrant Vector Database
# Get credentials from https://cloud.qdrant.io
QDRANT_URL="https://your-cluster.cloud.qdrant.io:6333"
QDRANT_API_KEY="your-qdrant-api-key"

# Embedding Configuration
# Options: tfidf (default, no setup), ollama (local), opencode (free models)
EMBEDDING_MODEL="tfidf"

# Local ML Models (Ollama) - Optional
# Install Ollama: https://ollama.ai
# Pull models: ollama pull nomic-embed-text && ollama pull llama3.2
OLLAMA_URL="http://localhost:11434"
DECISION_MODEL="llama3.2"

# Blog & LinkedIn Publishing
# Base URL for the blog (defaults to the homepage in package.json)
BLOG_BASE_URL="https://open-interview.github.io"

# LinkedIn API Configuration
LINKEDIN_ACCESS_TOKEN=""
LINKEDIN_PERSON_URN=""
# LinkedIn API Version (defaults to 202506)
LINKEDIN_API_VERSION="202506"
LINKEDIN_TOKEN_EXPIRY=""

# AI is powered by OpenCode CLI (no API keys required)
# Install: https://opencode.ai
# The opencode CLI handles all AI calls locally or via its own auth
OPENCODE_MODEL="opencode/gpt-5-nano"

# Static Build Mode (for GitHub Pages)
STATIC_BUILD="false"
